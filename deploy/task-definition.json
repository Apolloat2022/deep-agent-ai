{
  "family": "deep-agent-core-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::924056189531:role/deep-agent-core-execution-role",
  "taskRoleArn": "arn:aws:iam::924056189531:role/deep-agent-core-task-role",
  "containerDefinitions": [
    {
      "name": "deep-agent-core-service",
      "image": "924056189531.dkr.ecr.us-east-1.amazonaws.com/deep-agent-core-service:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "AGENT_ENV",
          "value": "prod"
        },
        {
          "name": "AWS_REGION",
          "value": "us-east-1"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:924056189531:secret:deep-agent-core-service/database-url-ECGYHx"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8080/healthz || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/deep-agent-core-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "deep-agent-core-service"
        }
      }
    }
  ]
}
